{
  "realm": "destiny",
  "enabled": true,
  "sslRequired": "none",
  "roles": {
    "realm": [
      {
        "name": "vocabulary.manager",
        "composite": true,
        "composites": { "realm": ["vocabulary.reviewer"] }
      },
      {
        "name": "vocabulary.reviewer",
        "composite": false
      }
    ]
  },
  "groups": [
    { "name": "vocabulary_managers", "realmRoles": ["vocabulary.manager"] },
    { "name": "vocabulary_reviewers", "realmRoles": ["vocabulary.reviewer"] }
  ],
  "clientScopes": [
    {
      "name": "openid",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "sub",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-sub-mapper",
          "config": {
            "access.token.claim": "true",
            "introspection.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "profile",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "username",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "username",
            "claim.name": "preferred_username",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        },
        {
          "name": "full name",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-full-name-mapper",
          "config": { "id.token.claim": "true", "access.token.claim": "true" }
        }
      ]
    },
    {
      "name": "email",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "email",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-attribute-mapper",
          "config": {
            "user.attribute": "email",
            "claim.name": "email",
            "jsonType.label": "String",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "roles",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "false" },
      "protocolMappers": [
        {
          "name": "realm roles",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-usermodel-realm-role-mapper",
          "config": {
            "multivalued": "true",
            "claim.name": "realm_access.roles",
            "jsonType.label": "String",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "groups",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "groups",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-group-membership-mapper",
          "config": {
            "full.path": "false",
            "claim.name": "groups",
            "id.token.claim": "true",
            "access.token.claim": "true"
          }
        }
      ]
    },
    {
      "name": "vocabulary.manager.all",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "audience-resolve",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-resolve-mapper"
        }
      ]
    },
    {
      "name": "vocabulary.reviewer.all",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" },
      "protocolMappers": [
        {
          "name": "audience-resolve",
          "protocol": "openid-connect",
          "protocolMapper": "oidc-audience-resolve-mapper"
        }
      ]
    },
    {
      "name": "mcp:tools",
      "description": "MCP tool invocation access",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" }
    },
    {
      "name": "mcp:prompts",
      "description": "MCP prompt access",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" }
    },
    {
      "name": "mcp:resources",
      "description": "MCP resource access",
      "protocol": "openid-connect",
      "attributes": { "include.in.token.scope": "true" }
    }
  ],
  "defaultDefaultClientScopes": [
    "openid",
    "profile",
    "email",
    "roles",
    "groups"
  ],
  "clientRegistrationPolicies": {
    "anonymous": [
      {
        "name": "Allowed Client Scopes",
        "providerId": "allowed-client-templates",
        "subType": "anonymous",
        "config": {
          "allow-default-scopes": ["true"],
          "allowed-client-scopes": [
            "openid",
            "profile",
            "email",
            "roles",
            "groups",
            "mcp:tools",
            "mcp:prompts",
            "mcp:resources",
            "vocabulary.manager.all"
          ]
        }
      },
      {
        "name": "Max Clients Limit",
        "providerId": "max-clients",
        "subType": "anonymous",
        "config": {
          "max-clients": ["200"]
        }
      }
    ],
    "authenticated": [
      {
        "name": "Allowed Client Scopes",
        "providerId": "allowed-client-templates",
        "subType": "authenticated",
        "config": {
          "allow-default-scopes": ["true"]
        }
      }
    ]
  },
  "clients": [
    {
      "clientId": "taxonomy-builder-api-local",
      "enabled": true,
      "bearerOnly": true,
      "publicClient": false,
      "protocol": "openid-connect"
    },
    {
      "clientId": "taxonomy-builder-ui-local",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "groups",
        "vocabulary.manager.all"
      ]
    },
    {
      "clientId": "taxonomy-reader-ui-local",
      "enabled": true,
      "publicClient": true,
      "standardFlowEnabled": true,
      "directAccessGrantsEnabled": true,
      "protocol": "openid-connect",
      "redirectUris": ["*"],
      "webOrigins": ["*"],
      "attributes": { "pkce.code.challenge.method": "S256" },
      "defaultClientScopes": [
        "openid",
        "profile",
        "email",
        "roles",
        "groups",
        "vocabulary.reviewer.all"
      ]
    }
  ],
  "users": [
    {
      "username": "admin",
      "email": "admin@localhost",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Admin",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "admin", "temporary": false }
      ],
      "groups": ["vocabulary_managers"]
    },
    {
      "username": "reviewer",
      "email": "reviewer@localhost",
      "emailVerified": true,
      "enabled": true,
      "firstName": "Reviewer",
      "lastName": "User",
      "credentials": [
        { "type": "password", "value": "reviewer", "temporary": false }
      ],
      "groups": ["vocabulary_reviewers"]
    }
  ]
}
